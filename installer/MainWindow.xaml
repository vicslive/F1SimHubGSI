<Window x:Class="F1SimHubLive.Installer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:F1SimHubLive.Installer"
        xmlns:models="clr-namespace:F1SimHubLive.Installer.Models"
        mc:Ignorable="d"
        Title="F1SimHubLive Installer" Height="640" Width="900"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="14"
        Background="#FF1A1A1A" Foreground="#FFE0E0E0">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FFCC0000"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FF3A3A3A"/>
                    <Setter Property="Foreground" Value="#FF808080"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFE0E0E0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- Header strip -->
        <Border Grid.Row="0" Background="#FF000000" BorderBrush="#FFCC0000" BorderThickness="0,0,0,2">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="F1" FontSize="36" FontWeight="Bold" Foreground="#FFCC0000" VerticalAlignment="Center"/>
                    <TextBlock Text="SimHubLive" FontSize="36" FontWeight="Light" Foreground="White" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <TextBlock x:Name="StepIndicator" FontSize="16" Foreground="#FFAAAAAA" VerticalAlignment="Center" Margin="40,0,0,0"
                               Text="Step 1 of 4 — Welcome"/>
                </StackPanel>
                <TextBlock Grid.Column="1" x:Name="VersionLabel" FontSize="13" Foreground="#FF888888"
                           VerticalAlignment="Center" HorizontalAlignment="Right"
                           Text="v?.?.?"/>
            </Grid>
        </Border>

        <!-- Page slots (one visible at a time). ScrollViewer so tall pages don't get clipped on smaller windows. -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      PanningMode="VerticalOnly">
        <Grid Margin="40,30">
            <!-- 1. Welcome -->
            <StackPanel x:Name="PageWelcome" Visibility="Visible">
                <Border x:Name="UpdateBanner" Visibility="Collapsed"
                        Background="#FF2A2410" BorderBrush="#FFE0B341" BorderThickness="1"
                        CornerRadius="4" Padding="14,10" Margin="0,0,0,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Name="UpdateBannerTitle" FontWeight="SemiBold" Foreground="#FFFFD970"
                                       Text="A newer installer is available"/>
                            <TextBlock x:Name="UpdateBannerSubtitle" TextWrapping="Wrap" Margin="0,2,0,0"
                                       Foreground="#FFCFCFCF" FontSize="12"/>
                        </StackPanel>
                        <Button x:Name="BtnUpdateDownload" Grid.Column="1" Content="Download" Click="BtnUpdateDownload_Click"
                                Margin="14,0,0,0" MinWidth="100" Padding="14,6"/>
                        <Button x:Name="BtnUpdateDismiss" Grid.Column="2" Content="Continue" Click="BtnUpdateDismiss_Click"
                                Margin="8,0,0,0" MinWidth="90" Padding="14,6"
                                Background="#FF3A3A3A"/>
                    </Grid>
                </Border>
                <TextBlock Text="Live F1 broadcast telemetry → SimHub → your wheel" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,16"/>
                <TextBlock TextWrapping="Wrap" LineHeight="22" Margin="0,0,0,12">
                    This installer deploys the F1SimHubLive SimHub plugin and the F1RaceSim_GSIFPEV2
                    dashboard onto this machine. After installation, you will be able to
                    watch a Formula 1 broadcast on F1 MultiViewer and have a live dashboard
                    (RPM, gear, speed, throttle, brake, sector times, gap to leader, flags,
                    weather, more) render on your SimHub-connected wheel screen. The current
                    F1RaceSim_GSIFPEV2 dashboard is laid out for an 800×480 wheel screen (tested on
                    GSI Formula Pro Elite V2 and GSI Hyper P1).
                </TextBlock>
                <TextBlock TextWrapping="Wrap" LineHeight="22" Margin="0,0,0,12">
                    Before you begin, please make sure:
                </TextBlock>
                <StackPanel Margin="20,0">
                    <TextBlock Text="• SimHub is installed (https://www.simhubdash.com/)"/>
                    <TextBlock Text="• F1 MultiViewer is installed and you are signed in with an active F1 TV subscription"/>
                    <TextBlock TextWrapping="Wrap" Text="• A Live Timing session is open in F1 MultiViewer — for a replay, click 'Replay Live Timing' on the session (just watching the video feed is NOT enough; telemetry only flows from the Live Timing view)"/>
                    <TextBlock Text="• Your wheel / dash screen is connected and showing up under SimHub Devices"/>
                </StackPanel>
                <TextBlock TextWrapping="Wrap" Margin="0,20,0,0" FontStyle="Italic" Foreground="#FFAAAAAA">
                    Click "Next" to verify your environment.
                </TextBlock>
            </StackPanel>

            <!-- 2. Prerequisites -->
            <StackPanel x:Name="PagePrereqs" Visibility="Collapsed">
                <TextBlock Text="Prerequisite check" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,20"/>

                <Border Background="#FF242424" CornerRadius="5" Padding="20,15" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="SimHubIcon" Grid.Column="0" Text="⏳" FontSize="28" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="SimHub" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock x:Name="SimHubStatus" Text="Checking..." Foreground="#FFAAAAAA"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="#FF242424" CornerRadius="5" Padding="20,15" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="MVIcon" Grid.Column="0" Text="⏳" FontSize="28" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="F1 MultiViewer (installed)" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock x:Name="MVStatus" Text="Checking..." Foreground="#FFAAAAAA"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="#FF242424" CornerRadius="5" Padding="20,15" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="MVApiIcon" Grid.Column="0" Text="⏳" FontSize="28" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="MultiViewer Live Timing active (signed into F1 TV + Live Timing view open)" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            <TextBlock x:Name="MVApiStatus" Text="Checking..." Foreground="#FFAAAAAA" TextWrapping="Wrap"/>
                            <TextBlock Foreground="#FF888888" FontSize="12" FontStyle="Italic" TextWrapping="Wrap"
                                       Text="Watching the F1 video feed alone is not enough. For a replay, click 'Replay Live Timing' on the session inside MultiViewer — that is what actually emits telemetry to localhost:10101."/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="#FF242424" CornerRadius="5" Padding="20,15" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="WheelIcon" Grid.Column="0" Text="⏳" FontSize="28" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Your wheel / dash device (read from SimHub Devices)" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            <TextBlock x:Name="WheelStatus" Text="Checking..." Foreground="#FFAAAAAA" TextWrapping="Wrap"/>
                            <TextBlock Foreground="#FF888888" FontSize="12" FontStyle="Italic" TextWrapping="Wrap"
                                       Text="F1SimHubLive picks up whatever LCD-capable wheels you have already configured in SimHub Devices. The F1RaceSim_GSIFPEV2 dashboard is laid out for an 800×480 wheel screen (GSI Formula Pro Elite V2, GSI Hyper P1 today); other resolutions may crop or scale."/>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Button x:Name="BtnRecheck" Content="Re-check" Click="BtnRecheck_Click"
                            Background="#FF333333"/>
                    <TextBlock x:Name="PrereqHint" Margin="20,0,0,0" VerticalAlignment="Center"
                               TextWrapping="Wrap" Foreground="#FFFFCC00"/>
                </StackPanel>
            </StackPanel>

            <!-- 3. Driver & source -->
            <StackPanel x:Name="PageDriver" Visibility="Collapsed">
                <TextBlock Text="Pick your driver and data source" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,20"/>

                <TextBlock Text="Driver" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBlock x:Name="DriverSourceLabel" Foreground="#FFAAAAAA" FontStyle="Italic" Margin="0,0,0,8"/>
                <ComboBox x:Name="CmbDriver" Padding="10,8" FontSize="14" Background="#FF242424" Foreground="Black"
                          DisplayMemberPath="DisplayName" />

                <TextBlock Text="Data source" FontSize="16" FontWeight="SemiBold" Margin="0,24,0,6"/>
                <RadioButton x:Name="RbMultiViewer" GroupName="Src" Margin="0,4" IsChecked="True" Foreground="#FFE0E0E0">
                    <StackPanel>
                        <TextBlock Text="F1 MultiViewer (recommended)" FontWeight="SemiBold"/>
                        <TextBlock Text="Reads telemetry from your local MultiViewer install — works for live broadcasts AND replays. Decompressed JSON, no SignalR negotiation."
                                   TextWrapping="Wrap" Foreground="#FFAAAAAA" FontSize="12"/>
                    </StackPanel>
                </RadioButton>
                <RadioButton x:Name="RbF1Live" GroupName="Src" Margin="0,4" Foreground="#FFE0E0E0">
                    <StackPanel>
                        <TextBlock Text="F1 Live (livetiming.formula1.com)" FontWeight="SemiBold"/>
                        <TextBlock Text="Plugin connects directly to the official SignalR feed. Live sessions only — no replay support."
                                   TextWrapping="Wrap" Foreground="#FFAAAAAA" FontSize="12"/>
                    </StackPanel>
                </RadioButton>

                <TextBlock Text="SimHub idle dashboard" FontSize="16" FontWeight="SemiBold" Margin="0,24,0,6"/>
                <Border Background="#FF242424" CornerRadius="4" Padding="14,12">
                    <StackPanel>
                        <CheckBox x:Name="ChkSetIdleDash" IsChecked="True" Foreground="#FFE0E0E0"
                                  FontWeight="SemiBold">
                            <TextBlock TextWrapping="Wrap">
                                Set F1RaceSim_GSIFPEV2 as my SimHub idle dashboard (recommended)
                            </TextBlock>
                        </CheckBox>
                        <TextBlock x:Name="IdleDashCurrentLabel" Margin="22,4,0,0"
                                   Foreground="#FFAAAAAA" FontSize="12" TextWrapping="Wrap"
                                   Text="Detecting current idle dashboard..."/>
                        <TextBlock Margin="22,6,0,0" Foreground="#FF888888" FontSize="12"
                                   TextWrapping="Wrap"
                                   Text="If you leave this unchecked, the F1RaceSim_GSIFPEV2 files will still be installed, but your SimHub screen will keep showing whatever idle dashboard you have today. You can change it later under SimHub → Dash Studio → your device → Idle dashboard."/>
                    </StackPanel>
                </Border>

                <Expander Header="Advanced settings" Foreground="#FFAAAAAA" Margin="0,20,0,0">
                    <StackPanel Margin="20,10,0,0">
                        <TextBlock Text="MultiViewer base URL" Margin="0,4,0,2"/>
                        <TextBox x:Name="TxtMvUrl" Text="http://localhost:10101" Padding="6,4" Background="#FF242424" Foreground="#FFE0E0E0" BorderBrush="#FF555555"/>
                        <TextBlock Text="Car-data poll interval (ms)" Margin="0,8,0,2"/>
                        <TextBox x:Name="TxtMvPoll" Text="250" Padding="6,4" Background="#FF242424" Foreground="#FFE0E0E0" BorderBrush="#FF555555"/>
                        <TextBlock Text="Timing poll interval (ms)" Margin="0,8,0,2"/>
                        <TextBox x:Name="TxtMvTimingPoll" Text="1000" Padding="6,4" Background="#FF242424" Foreground="#FFE0E0E0" BorderBrush="#FF555555"/>
                    </StackPanel>
                </Expander>
            </StackPanel>

            <!-- 4. Deploy -->
            <StackPanel x:Name="PageDeploy" Visibility="Collapsed">
                <TextBlock Text="Install" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,20"/>
                <TextBlock x:Name="DeploySummary" TextWrapping="Wrap" Margin="0,0,0,16"/>

                <ProgressBar x:Name="DeployProgress" Height="20" Minimum="0" Maximum="100"
                             Background="#FF242424" Foreground="#FFCC0000" BorderThickness="0"/>

                <TextBox x:Name="DeployLog" IsReadOnly="True" AcceptsReturn="True"
                         Background="#FF0A0A0A" Foreground="#FFAAEEAA" FontFamily="Consolas"
                         Height="240" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto"
                         BorderBrush="#FF333333"/>
            </StackPanel>

            <!-- 5. Done -->
            <StackPanel x:Name="PageDone" Visibility="Collapsed">
                <TextBlock Text="✓ All done" FontSize="32" FontWeight="Light" Foreground="#FF66CC66" Margin="0,0,0,20"/>
                <TextBlock TextWrapping="Wrap" LineHeight="22" Margin="0,0,0,12">
                    The F1SimHubLive plugin and F1RaceSim_GSIFPEV2 dashboard are installed.
                </TextBlock>

                <!-- Warning shown only when the user opted out of setting the idle dashboard -->
                <Border x:Name="IdleDashWarning" Visibility="Collapsed"
                        Background="#FF2A1E10" BorderBrush="#FFE08A41" BorderThickness="1"
                        CornerRadius="4" Padding="14,12" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="⚠  You declined to set F1RaceSim_GSIFPEV2 as your idle dashboard"
                                   FontWeight="SemiBold" Foreground="#FFFFCC88"/>
                        <TextBlock x:Name="IdleDashWarningDetail" TextWrapping="Wrap" Margin="0,6,0,0"
                                   Foreground="#FFE0E0E0" FontSize="13"
                                   Text="The F1RaceSim_GSIFPEV2 dashboard files have been copied into SimHub, but your idle dashboard is still pointing at something else. The F1 Live dashboard will only appear when you manually switch SimHub's idle dashboard to F1RaceSim_GSIFPEV2."/>
                        <TextBlock Margin="0,8,0,0" Foreground="#FFFFCC88" FontWeight="SemiBold" FontSize="13"
                                   Text="To enable it manually:"/>
                        <StackPanel Margin="14,4,0,0">
                            <TextBlock Text="1. Open SimHub" Foreground="#FFE0E0E0" FontSize="13"/>
                            <TextBlock Text="2. Go to Dash Studio (left sidebar)" Foreground="#FFE0E0E0" FontSize="13"/>
                            <TextBlock Text="3. Select your device (e.g. GSI Formula Pro Elite V2)" Foreground="#FFE0E0E0" FontSize="13"/>
                            <TextBlock Text="4. Set 'Idle dashboard' to F1RaceSim_GSIFPEV2" Foreground="#FFE0E0E0" FontSize="13"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Confirmation shown when we DID set the idle dashboard -->
                <Border x:Name="IdleDashConfirm" Visibility="Collapsed"
                        Background="#FF1E2A18" BorderBrush="#FF66CC66" BorderThickness="1"
                        CornerRadius="4" Padding="14,12" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="✓  F1RaceSim_GSIFPEV2 set as your SimHub idle dashboard"
                                   FontWeight="SemiBold" Foreground="#FFAAEEAA"/>
                        <TextBlock x:Name="IdleDashConfirmDetail" TextWrapping="Wrap" Margin="0,6,0,0"
                                   Foreground="#FFE0E0E0" FontSize="13"
                                   Text="When SimHub starts and no game is running, your wheel will show the F1 Live dashboard automatically."/>
                    </StackPanel>
                </Border>

                <TextBlock TextWrapping="Wrap" LineHeight="22" Margin="0,0,0,12">
                    To finish:
                </TextBlock>
                <StackPanel Margin="20,0">
                    <TextBlock Text="• Open SimHub → Settings → Plugins → enable F1SimHubLive"/>
                    <TextBlock Text="• Open SimHub → Devices → your GSI wheel → LEDs → pick the F1 Live LED profile (or build your own bound to F1SimHubLivePlugin.* properties)"/>
                    <TextBlock Text="• Open Dash Studio → F1RaceSim_GSIFPEV2 and check the dashboard renders"/>
                    <TextBlock Text="• Start F1 MultiViewer, sign in to F1 TV, load a session, and open Live Timing (for replays: click 'Replay Live Timing' on the session). Watching only the video feed is not enough — telemetry to localhost:10101 only flows from the Live Timing view."/>
                </StackPanel>
                <TextBlock TextWrapping="Wrap" Margin="0,20,0,0" Foreground="#FFAAAAAA">
                    Docs and updates: https://github.com/vicslive/F1SimHubLive
                </TextBlock>
            </StackPanel>
        </Grid>
        </ScrollViewer>

        <!-- Footer with nav buttons -->
        <Border Grid.Row="2" Background="#FF0F0F0F" BorderBrush="#FF333333" BorderThickness="0,1,0,0">
            <Grid Margin="20,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Button x:Name="BtnBack" Content="Back" Click="BtnBack_Click"
                            Background="#FF333333" IsEnabled="False"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnCancel" Content="Cancel" Click="BtnCancel_Click"
                            Background="#FF333333" Margin="0,0,10,0"/>
                    <Button x:Name="BtnNext" Content="Next" Click="BtnNext_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

