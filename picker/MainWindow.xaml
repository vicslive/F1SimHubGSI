<Window x:Class="F1SimHubLive.Picker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:F1SimHubLive.Picker.Services"
        xmlns:models="clr-namespace:F1SimHubLive.Picker.Models"
        Title="F1SimHubLive — Driver Picker"
        Icon="Assets/picker.ico"
        Width="360" Height="740"
        MinWidth="300" MinHeight="420"
        Background="#0F0F12"
        Foreground="#E8E8EC"
        FontFamily="Segoe UI"
        Topmost="True"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <svc:HexToBrushConverter x:Key="HexToBrush" />

        <Style x:Key="DriverButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1A1A20" />
            <Setter Property="BorderBrush" Value="#2A2A33" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#E8E8EC" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#23232C" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2E2E3A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                    <Setter Property="BorderBrush" Value="#3FD06A" />
                    <Setter Property="BorderThickness" Value="2" />
                    <Setter Property="Background" Value="#1B2A1F" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True" Margin="10">

        <!-- Header -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="DRIVER PICKER" FontSize="11" FontWeight="SemiBold"
                           Foreground="#7F7F8A" />
                <TextBlock x:Name="CurrentDriverText"
                           Text="—" FontSize="20" FontWeight="Bold" Margin="0,2,0,0" />
            </StackPanel>
            <CheckBox Grid.Column="1" x:Name="TopmostCheck"
                      Content="📌 Pin" IsChecked="True"
                      Foreground="#C8C8D0"
                      VerticalAlignment="Center"
                      Checked="TopmostCheck_Changed"
                      Unchecked="TopmostCheck_Changed" />
        </Grid>

        <!-- Status bar -->
        <Border DockPanel.Dock="Top" Background="#15151B"
                CornerRadius="4" Padding="8,5" Margin="0,0,0,8">
            <TextBlock x:Name="StatusText"
                       Text="Connecting to MultiViewer…"
                       FontSize="11" Foreground="#9090A0"
                       TextTrimming="CharacterEllipsis" />
        </Border>

        <!-- Footer -->
        <TextBlock DockPanel.Dock="Bottom"
                   x:Name="SettingsPathText"
                   Text=""
                   FontSize="10" Foreground="#55555F"
                   TextTrimming="CharacterEllipsis"
                   Margin="0,8,0,0"
                   ToolTipService.ShowDuration="20000" />

        <!-- Driver list -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="DriverList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:DriverEntry}">
                        <Button Style="{StaticResource DriverButtonStyle}"
                                Margin="0,0,0,6"
                                Click="DriverButton_Click"
                                Tag="{Binding Number}">
                            <Grid Height="64">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="64" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <!-- Team-colour TLA tile -->
                                <Border Grid.Column="0"
                                        Background="{Binding TeamColour, Converter={StaticResource HexToBrush}}"
                                        CornerRadius="3,0,0,3">
                                    <TextBlock Text="{Binding Tla}"
                                               Foreground="White"
                                               FontSize="24" FontWeight="Black"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <!-- Name block -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                            Margin="10,0,4,0">
                                    <TextBlock Text="{Binding DisplayLastName}"
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="#FFFFFF"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding TeamName}"
                                               FontSize="10"
                                               Foreground="#9898A4"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,1,0,0" />
                                </StackPanel>
                                <!-- Big number + points stack -->
                                <StackPanel Grid.Column="2"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Margin="0,0,12,0">
                                    <TextBlock Text="{Binding Number}"
                                               FontSize="28" FontWeight="Black"
                                               Foreground="#3C3C48"
                                               HorizontalAlignment="Right"
                                               LineHeight="30"
                                               LineStackingStrategy="BlockLineHeight" />
                                    <TextBlock Text="{Binding DriverPointsDisplay}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="#6F6F7C"
                                               HorizontalAlignment="Right"
                                               Margin="0,-2,0,0" />
                                </StackPanel>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
